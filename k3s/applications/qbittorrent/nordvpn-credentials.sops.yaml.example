# Copy this file to nordvpn-credentials.sops.yaml and encrypt with SOPS before committing.
# The nordvpn-credentials secret is shared with sabnzbd — if the secret already exists
# in the cluster from the sabnzbd deployment, you do NOT need to re-apply it here.
# Only include this file if you need a separate secret for the qbittorrent namespace.
#
# To create:
#   cp nordvpn-credentials.sops.yaml.example nordvpn-credentials.sops.yaml
#   # Edit the file with your actual WireGuard private key
#   SOPS_AGE_KEY_FILE=~/.kube/k3s-homelab-age.agekey sops --encrypt --in-place nordvpn-credentials.sops.yaml
apiVersion: v1
kind: Secret
metadata:
  name: nordvpn-credentials
  namespace: qbittorrent
type: Opaque
stringData:
  wireguard-private-key: "YOUR_NORDVPN_WIREGUARD_PRIVATE_KEY_HERE"
